{
  "name": "nullscript-lang",
  "version": "3.0.0",
  "description": "NullScript - A linguagem de programação em português com IA integrada",
  "main": "nullscript.js",
  "bin": {
    "nullscript": "nullscript.js",
    "ns": "nullscript.js",
    "null": "nullscript.js"
  },
  "scripts": {
    "start": "node nullscript.js",
    "repl": "node nullscript.js --repl",
    "test": "node nullscript.js test/test.ns",
    "build": "node nullscript.js --compile examples/hello.ns",
    "docs": "node nullscript.js --doc examples/hello.ns"
  },
  "keywords": [
    "nullscript",
    "linguagem",
    "programacao",
    "portugues",
    "ia",
    "facil",
    "educacional"
  ],
  "author": "NullScript Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nullscript/nullscript"
  },
  "bugs": {
    "url": "https://github.com/nullscript/nullscript/issues"
  },
  "homepage": "https://nullscript.dev",
  "dependencies": {
    "readline": "^1.3.0",
    "crypto": "^1.0.1",
    "os": "^0.1.2",
    "fs": "^0.0.1-security",
    "path": "^0.12.7",
    "child_process": "^1.0.2",
    "events": "^3.3.0",
    "https": "^1.0.0",
    "url": "^0.11.0",
    "net": "^1.0.2",
    "dns": "^0.2.2",
    "vm": "^0.1.0",
    "zlib": "^1.0.5",
    "querystring": "^0.2.1",
    "util": "^0.12.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}